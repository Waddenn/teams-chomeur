{
  "manifest_version": 3,
  "name": "Teams Keyword Alerts",
  "description": "Trigger browser notifications when configured words appear in Microsoft Teams captions.",
  "version": "0.1.0",
  "permissions": ["notifications", "storage"],
  "host_permissions": [
    "https://teams.cloud.microsoft/*",
    "https://teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.cloud.microsoft/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "Teams Keyword Alerts",
    "default_popup": "src/options.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  }
}
